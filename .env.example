# ============================================================================
# OPS Web — Environment Variables
# ============================================================================
# Single source of truth. Keep in sync with Vercel project settings.
#
# Legend:
#   [V] = Already configured in Vercel (Production/Preview/Development)
#   [_] = NOT in Vercel — must be added if needed
#
# To run locally, copy this file to .env.local and fill in values.
# Or pull from Vercel:  npx vercel env pull .env.local
# ============================================================================

# --- Firebase (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=                        # [V]
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=                     # [V]
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ops-ios-app           # [V]
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=                  # [V]
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=             # [V]
NEXT_PUBLIC_FIREBASE_APP_ID=                          # [V]
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=                  # [V]

# --- Firebase Admin (server-only) ---
FIREBASE_ADMIN_PRIVATE_KEY=                           # [V] PEM key from service account JSON (newlines as \n)
FIREBASE_ADMIN_CLIENT_EMAIL=                          # [V] e.g. firebase-adminsdk-fbsvc@ops-ios-app.iam.gserviceaccount.com
FIREBASE_ADMIN_PROJECT_ID=                            # [V] (code uses NEXT_PUBLIC_ version above, but this also exists in Vercel)
# FIREBASE_ADMIN_SERVICE_ACCOUNT=                     # [_] Optional: full JSON alternative to individual vars above

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=                             # [V]
NEXT_PUBLIC_SUPABASE_ANON_KEY=                        # [V]
SUPABASE_SERVICE_ROLE_KEY=                            # [V] Settings → API → service_role key (bypasses RLS)

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=                   # [V]
STRIPE_SECRET_KEY=                                    # [V]
STRIPE_WEBHOOK_SECRET=                                # [V]
STRIPE_PRICE_STARTER_MONTHLY=price_1S6Jz1EooJoYGoIwDwx7dQHJ          # [_] Starter monthly  CAD $90 / mo (prod_T2OmEVtkZGSRNJ)
STRIPE_PRICE_STARTER_ANNUAL=price_1S6Jz1EooJoYGoIwiGXZJ2a7           # [_] Starter annual   CAD $864 / yr (prod_T2OmEVtkZGSRNJ)
STRIPE_PRICE_TEAM_MONTHLY=price_1S6Jz6EooJoYGoIwRoQIstPk             # [_] Team monthly     CAD $140 / mo (prod_T2OmuxGqXhWvOT)
STRIPE_PRICE_TEAM_ANNUAL=price_1S6Jz6EooJoYGoIwQSRdxhRs              # [_] Team annual      CAD $1,344 / yr (prod_T2OmuxGqXhWvOT)
STRIPE_PRICE_BUSINESS_MONTHLY=price_1S6Jz8EooJoYGoIw9u8cb3lx         # [_] Business monthly CAD $190 / mo (prod_T2Omjg1JJbnmWp)
STRIPE_PRICE_BUSINESS_ANNUAL=price_1S6Jz8EooJoYGoIwB2IUeC6z          # [_] Business annual  CAD $1,824 / yr (prod_T2Omjg1JJbnmWp)

# --- Stripe Add-ons ---
STRIPE_PRICE_DATA_SETUP=price_1S6c4FEooJoYGoIwIHx3gzQA              # [_] One-time Data Setup CAD $399 (prod_T2hTzqU8jtkKtU)
STRIPE_PRICE_PRIORITY_SUPPORT_MONTHLY=price_1S6JzBEooJoYGoIwQao1bUgL # [_] Priority Support monthly CAD $57 / mo (prod_T2Oma02k2JuZlO)
STRIPE_PRICE_PRIORITY_SUPPORT_ANNUAL=price_1S6JzBEooJoYGoIwAOU9FYvq  # [_] Priority Support annual CAD $547.20 / yr (prod_T2Oma02k2JuZlO)
ADDON_FULFILLMENT_EMAIL=jack@opsapp.co                # [_] Inbox that receives Data Setup purchase notifications

# --- AWS S3 (image uploads) ---
AWS_ACCESS_KEY_ID=                                    # [_]
AWS_SECRET_ACCESS_KEY=                                # [_]
AWS_S3_BUCKET=ops-app-files-prod                      # [_]
AWS_REGION=us-west-2                                  # [_]

# --- SendGrid (portal emails) ---
SENDGRID_API_KEY=                                     # [V]
SENDGRID_FROM_EMAIL=noreply@opsapp.co                 # [V]

# --- Gmail OAuth (email integration) ---
GOOGLE_GMAIL_CLIENT_ID=                               # [V]
GOOGLE_GMAIL_CLIENT_SECRET=                           # [V]
# Redirect URI = NEXT_PUBLIC_BASE_URL + /api/integrations/gmail/callback
GOOGLE_PUBSUB_TOPIC=                                  # [_] projects/<project>/topics/<topic> for Gmail push

# --- Google Ads API (service account auth — uses Firebase service account) ---
GOOGLE_ADS_DEVELOPER_TOKEN=                           # [V] from ads.google.com/aw/apicenter
GOOGLE_ADS_CUSTOMER_ID=5448339076                     # [V] OPS LTD, no dashes

# --- Microsoft 365 OAuth (email integration) ---
MICROSOFT_CLIENT_ID=                                  # [_] Azure AD App Registration
MICROSOFT_CLIENT_SECRET=                              # [_] Azure AD App Registration
MICROSOFT_TENANT_ID=common                            # [_] "common" for multi-tenant
# Redirect URI = NEXT_PUBLIC_BASE_URL + /api/integrations/microsoft365/callback

# --- QuickBooks Online (accounting integration) ---
QB_CLIENT_ID=                                         # [_] Intuit developer app client ID
QB_CLIENT_SECRET=                                     # [_] Intuit developer app client secret
QB_REDIRECT_URI=https://app.opsapp.co/api/integrations/quickbooks/callback  # [_]
QB_ENVIRONMENT=sandbox                                # [_] sandbox or production
QB_TOKEN_ENC_KEY=                                     # [_] base64 32-byte AES key for OAuth secrets at rest (`openssl rand -base64 32`)
QB_WEBHOOK_VERIFIER_TOKEN=                            # [_] Verifier Token from the Intuit app dashboard (signs inbound webhooks; receiver fails closed if unset)

# --- Sage Accounting (accounting integration) ---
SAGE_CLIENT_ID=                                       # [_] Sage developer app client ID
SAGE_CLIENT_SECRET=                                   # [_] Sage developer app client secret
SAGE_REDIRECT_URI=https://app.opsapp.co/api/integrations/sage/callback  # [_]

# --- Google Analytics (admin panel) ---
GA4_PROPERTY_ID=                                      # [_] GA4 → Admin → Property Settings (numbers only)

# --- Blog API (n8n automation) ---
BLOG_API_KEY=                                         # [_] API key for programmatic blog post creation

# --- App URLs ---
NEXT_PUBLIC_APP_URL=https://app.opsapp.co             # [V]
NEXT_PUBLIC_BASE_URL=https://app.opsapp.co            # [V]

# --- Apple Sign-In ---
APPLE_CLIENT_ID=                                      # [V]

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=                                   # [V]
TWILIO_AUTH_TOKEN=                                    # [V]
TWILIO_PHONE_NUMBER=                                  # [V]

# --- OneSignal (push notifications) ---
ONESIGNAL_APP_ID=                                     # [_] OneSignal App ID (Settings → Keys & IDs)
ONESIGNAL_REST_API_KEY=                               # [_] OneSignal REST API Key (Settings → Keys & IDs)

# --- Cron Jobs ---
CRON_SECRET=                                          # [V]

# --- Google Analytics (client measurement) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=                        # [V]

# --- Google OAuth (client sign-in) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=                         # [V]

# --- OpenAI (email AI — separated by context for billing/rate-limit isolation) ---
OPENAI_API_KEY=                                       # [V] Shared fallback — used if context-specific keys are not set
OPENAI_API_KEY_IMPORT=                                # [_] Initial inbox scan (Phase A triage + Phase B extraction)
OPENAI_API_KEY_SYNC=                                  # [_] Ongoing sync (stage evaluation, memory, writing profiles)
OPENAI_API_KEY_DRAFTING=                              # [_] Email draft generation (future)
OPS_PLATFORM_ALERT_USER_ID=                           # [_] Canonical OPS users.id that receives platform-provider incidents
OPS_PLATFORM_ALERT_COMPANY_ID=                        # [_] Required company invariant for OPS_PLATFORM_ALERT_USER_ID

# --- Tavily (web search for AI agent) ---
TAVILY_API_KEY=                                       # [V] free tier at tavily.com

# --- Optional ---
# NEXT_PUBLIC_SENTRY_DSN=                             # [_] Sentry error tracking

# PMF Tracking Dashboard
PMF_NOTIFICATION_SMS=+1XXXXXXXXXX
PMF_NOTIFICATION_EMAIL=you@example.com
PMF_OPERATOR_USER_ID=<supabase auth user id for operator>
PMF_OPERATOR_COMPANY_ID=<company id this operator belongs to>
