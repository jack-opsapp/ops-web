ing this because you subscribed to <!-- -->OPS account notifications<!-- -->.<!-- --> <!-- -->write us at<!-- --> <a href="mailto:support@opsapp.co" style="color:rgba(255,255,255,0.64);text-decoration-line:none;text-decoration:underline" target="_blank">support@opsapp.co</a>.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background:#0A0A0A;padding:16px 32px 32px"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:12px;line-height:18px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;color:rgba(255,255,255,0.72);margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">OPS Ltd. — Built by trades, for trades.<br/><a href="https://app.opsapp.co" style="color:rgba(255,255,255,0.72);text-decoration-line:none;text-decoration:none" target="_blank">app.opsapp.co</a></p><p style="font-size:11px;line-height:16px;margin:8px 0 0 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.44);margin-top:8px;margin-right:0;margin-bottom:0;margin-left:0">Sent from <!-- -->dispatch@opsapp.co</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"
