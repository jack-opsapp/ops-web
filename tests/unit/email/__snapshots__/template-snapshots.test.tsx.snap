lPadding="0" cellSpacing="0" role="presentation" style="background:#0A0A0A;padding:16px 32px 32px"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:12px;line-height:18px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;color:rgba(255,255,255,0.72);margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">OPS Ltd. — Built by trades, for trades.<br/><a href="https://app.opsapp.co" style="color:rgba(255,255,255,0.72);text-decoration-line:none;text-decoration:none" target="_blank">app.opsapp.co</a></p><p style="font-size:11px;line-height:16px;margin:8px 0 0 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.44);margin-top:8px;margin-right:0;margin-bottom:0;margin-left:0">Sent from <!-- -->gate@opsapp.co</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"
`;

exports[`Email template snapshots > FieldNotesNewsletter renders with PreviewProps and brand markers 1`] = `
"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/><meta name="color-scheme" content="light dark"/><meta name="supported-color-schemes" content="light dark"/><style>
    @font-face {
      font-family: 'Mohave';
      font-style: normal;
      font-weight: 400;
      mso-font-alt: 'Helvetica';
      src: url(https://fonts.googleapis.com/css2?family=Mohave:wght@400;500;600;700&display=swap) format('woff2');
    }

    * {
      font-family: 'Mohave', Helvetica;
    }
  </style><style>
    @font-face {
      font-family: 'JetBrains Mono';
      font-style: normal;
      font-weight: 400;
      mso-font-alt: 'monospace';
      src: url(https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap) format('woff2');
    }

    * {
      font-family: 'JetBrains Mono', monospace;
    }
  </style></head><body style="background:#0A0A0A;margin:0;padding:0"><!--$--><!--html--><!--head--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Spring&#x27;s here and every crew on our customer list is booked solid. This issue: what we shipped this month, plus a closer look at why the trades are pu</div><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="margin:0;padding:0;background:#0A0A0A;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:560px;width:100%;margin:0 auto;padding:0"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background:#0A0A0A;padding:40px 32px"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:1;margin:0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:#FFFFFF;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">OPS</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column" style="padding-top:32px"><p style="font-size:11px;line-height:14px;margin:0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.64);margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">Field notes — issue #12 — April 2026</p></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background:#F6F4EF;padding:40px 32px"><tbody><tr><td><h1 style="margin:0 0 16px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:28px;line-height:34px;font-weight:600;color:#0A0A0A;letter-spacing:0.02em">Field Notes — Issue #<!-- -->12</h1><p style="font-size:13px;line-height:20px;margin:0 0 16px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:400;color:rgba(10,10,10,0.56);margin-top:0;margin-right:0;margin-bottom:16px;margin-left:0">Jackson<!-- -->,</p><p style="font-size:16px;line-height:24px;margin:0 0 16px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:400;color:rgba(10,10,10,0.84);margin-top:0;margin-right:0;margin-bottom:16px;margin-left:0">Spring&#x27;s here and every crew on our customer list is booked solid. This issue: what we shipped this month, plus a closer look at why the trades are pulling away from enterprise PM tools.</p><p style="font-size:11px;line-height:14px;margin:32px 0 24px 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:rgba(10,10,10,0.56);border-bottom:1px solid rgba(10,10,10,0.12);padding-bottom:8px;margin-top:32px;margin-right:0;margin-bottom:24px;margin-left:0">From the shop — what&#x27;s new at OPS</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin:0 0 32px 0"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:24px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:600;color:#0A0A0A;letter-spacing:0.02em;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Deck Builder is live for beta testers</p><div style="font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:16px;line-height:24px;color:rgba(10,10,10,0.84)"><p>The in-app deck drawing tool shipped to our first 20 beta contractors last week. Early feedback: the laser measurement integration is the killer feature. We&#x27;re pushing to open it wider in May.</p></div><p style="font-size:11px;line-height:14px;margin:16px 0 0 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:#0A0A0A;margin-top:16px;margin-right:0;margin-bottom:0;margin-left:0"><a href="https://opsapp.co/blog/deck-builder-beta" style="color:#0A0A0A;text-decoration:underline">Read the announcement<!-- --> →</a></p></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin:0 0 32px 0"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:24px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:600;color:#0A0A0A;letter-spacing:0.02em;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">New: weekly ads intelligence briefings</p><div style="font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:16px;line-height:24px;color:rgba(10,10,10,0.84)"><p>If you&#x27;re running Google Ads, you&#x27;re now getting a Monday morning briefing with insights, recommended keyword moves, and a prioritized action list. Nobody else in the trades-software space ships anything close to this.</p></div></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin:0 0 32px 0"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:24px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:600;color:#0A0A0A;letter-spacing:0.02em;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Notification rail on the web app</p><div style="font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:16px;line-height:24px;color:rgba(10,10,10,0.84)"><p>Everything that matters — task completions, scan results, payment confirmations — now surfaces in a left-rail feed on the web dashboard. No more hunting through email to see what happened overnight.</p></div></td></tr></tbody></table></td></tr></tbody></table><p style="font-size:11px;line-height:14px;margin:32px 0 24px 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:rgba(10,10,10,0.56);border-bottom:1px solid rgba(10,10,10,0.12);padding-bottom:8px;margin-top:32px;margin-right:0;margin-bottom:24px;margin-left:0">From the field — industry insights</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin:0 0 32px 0"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:24px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:600;color:#0A0A0A;letter-spacing:0.02em;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">ServiceTitan IPO&#x27;d at $9B and its customers are revolting</p><div style="font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:16px;line-height:24px;color:rgba(10,10,10,0.84)"><p>ServiceTitan has doubled its prices in the last 18 months. Watching the Reddit threads is like watching a slow-motion crew mutiny. The takeaway: trades businesses remember when the software worked <em>for</em> them, not the other way around.</p></div><p style="font-size:11px;line-height:14px;margin:16px 0 0 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:#0A0A0A;margin-top:16px;margin-right:0;margin-bottom:0;margin-left:0"><a href="https://opsapp.co/blog/servicetitan-revolt" style="color:#0A0A0A;text-decoration:underline">Our full take<!-- --> →</a></p></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="margin:0 0 32px 0"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:18px;line-height:24px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:600;color:#0A0A0A;letter-spacing:0.02em;margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">Why your crew still uses group texts for schedules</p><div style="font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-size:16px;line-height:24px;color:rgba(10,10,10,0.84)"><p>A survey of 200 operators in Q1 showed 78% still rely on group SMS as the primary daily-schedule communication channel. The software market has been trying to kill text messages for a decade and it hasn&#x27;t worked. We dug into why.</p></div></td></tr></tbody></table></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid rgba(10,10,10,0.12);margin:24px 0"/><p style="font-size:13px;line-height:20px;margin:0 0 16px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;font-weight:400;color:rgba(10,10,10,0.56);margin-top:0;margin-right:0;margin-bottom:16px;margin-left:0">That&#x27;s it for this issue. Got something worth pinning to the crew truck? Reply to this email — we read everything.</p><div style="height:24px;line-height:24px;font-size:1px"> </div><a href="https://opsapp.co/field-notes/issue-12" style="line-height:1;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background:#0A0A0A;color:#FFFFFF;padding:16px 32px;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;font-size:13px;font-weight:400;letter-spacing:1.8px;text-transform:uppercase;border-radius:2px;border:1px solid #0A0A0A;padding-top:16px;padding-right:32px;padding-bottom:16px;padding-left:32px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:24" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:12px">Read the full issue →</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background:#0A0A0A;padding:0 32px 32px"><tbody><tr><td><hr style="width:100%;border:none;border-top:none;border-color:rgba(255,255,255,0.08);border-bottom:1px solid rgba(255,255,255,0.08);margin:0 0 24px 0"/><p style="font-size:11px;line-height:14px;margin:0 0 8px 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.44);margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">// <!-- -->OPS LTD.</p><p style="font-size:12px;line-height:18px;margin:0 0 16px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;color:rgba(255,255,255,0.64);margin-top:0;margin-right:0;margin-bottom:16px;margin-left:0">1515 Douglas St, Victoria, BC V8W 2G4, Canada</p><p style="font-size:12px;line-height:18px;margin:0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;color:rgba(255,255,255,0.44);margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">You&#x27;re receiving this because you subscribed to <!-- -->OPS account notifications<!-- -->.<!-- --> <a href="https://opsapp.co/unsubscribe?email=preview@example.com" style="color:rgba(255,255,255,0.64);text-decoration-line:none;text-decoration:underline" target="_blank">Unsubscribe</a> or <!-- -->write us at<!-- --> <a href="mailto:support@opsapp.co" style="color:rgba(255,255,255,0.64);text-decoration-line:none;text-decoration:underline" target="_blank">support@opsapp.co</a>.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background:#0A0A0A;padding:16px 32px 32px"><tbody><tr><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation"><tbody style="width:100%"><tr style="width:100%"><td data-id="__react-email-column"><p style="font-size:12px;line-height:18px;margin:0 0 8px 0;font-family:Mohave, &#x27;Helvetica Neue&#x27;, Arial, sans-serif;color:rgba(255,255,255,0.72);margin-top:0;margin-right:0;margin-bottom:8px;margin-left:0">OPS Ltd. — Built by trades, for trades.<br/><a href="https://app.opsapp.co" style="color:rgba(255,255,255,0.72);text-decoration-line:none;text-decoration:none" target="_blank">app.opsapp.co</a></p><p style="font-size:11px;line-height:16px;margin:8px 0 0 0;font-family:&#x27;JetBrains Mono&#x27;, &#x27;SFMono-Regular&#x27;, Menlo, Consolas, &#x27;Liberation Mono&#x27;, monospace;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.44);margin-top:8px;margin-right:0;margin-bottom:0;margin-left:0">Sent from <!-- -->field@opsapp.co</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"
`;

exports[`Email template snapshots > PasswordReset renders with PreviewProps and brand markers 1`] = `
"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/><meta name="color-scheme" content="light dark"/><meta name="supported-color-schemes" content="light dark"/><style>
    @font-face {
      font-family: 'Mohave';
      font-style: normal;
      font-weight: 400;
      mso-font-alt: 'Helvetica';
      src: url(https://fonts.googleapis.com/css2?family=Mohave:wght@400;500;600;700&display=swap) format('woff2');
    }

    * {
      font-family: 'Mohave', Helvetica;
    }
  </style><style>
    @font-face {
      font-family: 'JetBrains Mono';
      font-style: normal;
      font-weight: 400;
      mso-font-alt: 'monospace';
      src: url(https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap) format('woff2');
    }

    * {
